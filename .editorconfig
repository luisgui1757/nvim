root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,c,cpp,cc,h,hpp,rs,go}]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{ps1,psm1,psd1}]
end_of_line = lf
indent_size = 4

[*.{bat,cmd}]
end_of_line = crlf
indent_size = 4

[*.{toml,yml,yaml,json,jsonc,sh,zsh,bash}]
indent_size = 2

[*.lua]
indent_style = space
indent_size = 2
