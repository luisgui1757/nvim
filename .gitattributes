# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts MUST stay LF even on Windows checkouts (core.autocrlf=true),
# otherwise WSL / Git-Bash fail with `bad interpreter: /usr/bin/env bash^M`.
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf
zshrc   text eol=lf
*.toml  text eol=lf
*.lua   text eol=lf
*.conf  text eol=lf

# PowerShell + Windows batch want CRLF.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf
