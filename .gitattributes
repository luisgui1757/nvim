# Auto detect text files and perform LF normalization
* text=auto

# Force LF on every text file regardless of platform / core.autocrlf, so a
# Windows checkout never CRLF-corrupts shell scripts (which would break WSL /
# Git-Bash with `bad interpreter: /usr/bin/env bash^M`). This matches
# .editorconfig (end_of_line = lf) — including .ps1, which PowerShell / pwsh
# run fine with LF. Do NOT add eol=crlf overrides; they conflict with
# .editorconfig and the editorconfig-checker CI step.
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf
zshrc   text eol=lf
*.toml  text eol=lf
*.lua   text eol=lf
*.conf  text eol=lf
*.ps1   text eol=lf
