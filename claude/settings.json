{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git merge:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git mv:*)",
      "Bash(git -C:*)",
      "Bash(git submodule:*)",
      "Bash(git rm:*)",
      "Bash(git config:*)",
      "Bash(git reset:*)",
      "Bash(git update-ref:*)",
      "Bash(git check-ignore:*)",
      "Bash(git ls-tree:*)",
      "Bash(make:*)",
      "Bash(make help:*)",
      "Bash(make test:*)",
      "Bash(make build:*)",
      "Bash(make install:*)",
      "Bash(make ci:*)",
      "Bash(make check:*)",
      "Bash(make fmt:*)",
      "Bash(make dev:*)",
      "Bash(make smoke:*)",
      "Bash(make --version:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npx:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx vitest:*)",
      "Bash(npx vite build:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(pip install:*)",
      "Bash(pip show:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(gh auth:*)",
      "Bash(gh auth status:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(gh run list:*)",
      "Bash(gh run watch:*)",
      "Bash(gh run view:*)",
      "Bash(gh repo:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr:*)",
      "Bash(gh pr close:*)",
      "Bash(gh search:*)",
      "Bash(chmod:*)",
      "Bash(open:*)",
      "Bash(echo:*)",
      "Bash(source:*)",
      "Bash(brew install:*)",
      "Bash(curl:*)",
      "Bash(lsof:*)",
      "Bash(xargs kill:*)",
      "Bash(node -e:*)",
      "Bash(which cargo:*)",
      "Bash(which rustc:*)",
      "Bash(which pyinstaller:*)",
      "Bash(do git:*)",
      "Bash(done)",
      "Bash(while read:*)",
      "Bash(for i:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:developers.google.com)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:deepwiki.com)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "command -v pwsh >/dev/null && pwsh -NoProfile -File \"$HOME/.claude/statusline-command.ps1\" || bash \"$HOME/.claude/statusline-command.sh\""
  },
  "enabledPlugins": {
    "impeccable@impeccable": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      },
      "autoUpdate": true
    },
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "theme": "dark-ansi",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
